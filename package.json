{
  "name": "dagre-d3",
  "version": "0.6.5-pre",
  "description": "A D3-based renderer for Dagre",
  "author": "Chris Pettitt <chris@samsarin.com>",
  "main": "dist/dagre-d3.cjs.js",
  "module": "dist/dagre-d3.esm.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/dagre-d3.esm.js",
      "require": "./dist/dagre-d3.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run version:make && npm run build:types && tsx build.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts --ignore-pattern demo --ignore-pattern dist --ignore-pattern build",
    "test": "npm run build && vitest run",
    "version:make": "tsx src/release/make-version.ts > lib/version.ts",
    "version:check": "tsx src/release/check-version.ts",
    "version:bump": "tsx src/release/bump-version.ts",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "graph",
    "dagre",
    "graphlib",
    "renderer"
  ],
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@dagrejs/graphlib": "^4.0.1",
    "d3": "^7.9.0",
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "esbuild": "^0.27.3",
    "eslint": "8.15.0",
    "jsdom": "^24.1.3",
    "semver": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^4.9.5",
    "vitest": "^1.6.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dagrejs/dagre-d3.git"
  },
  "license": "MIT"
}
